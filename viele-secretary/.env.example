# =============================================================
#  VIELE secretary — 環境変数テンプレート
#  このファイルを .env にコピーして値を埋める： cp .env.example .env
#  ※ VITE_ 接頭辞の付いた変数だけがフロントのバンドルに埋め込まれます（＝公開されてOKな値のみ）。
#    接頭辞なしの変数はサーバー(api/)専用のシークレットです。クライアントには出ません。
# =============================================================

# ── フロント：Firebase 設定（プロジェクト設定 > マイアプリ の firebaseConfig）──
# Webの firebaseConfig は公開前提の値（apiKey含む）。配布時は各自のFirebaseプロジェクトの値に。
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_FB_MEASUREMENT_ID=

# ── フロント：Webプッシュの公開鍵（VAPID公開鍵と同じ値を入れる）──
VITE_VAPID_PUBLIC_KEY=

# =============================================================
#  ここから下はサーバー(api/)専用シークレット。Vercelの Environment Variables に設定。
#  絶対にクライアントへ露出させない（VITE_ を付けない）。
# =============================================================

# ── AI（運気・ニュース要約・告知文）──
GEMINI_API_KEY=
# 任意：使用するGeminiモデルを固定したい場合（未設定なら自動選択）
GEMINI_MODEL=

# ── Googleカレンダー連携（OAuth）──
# Google Cloud Console の OAuth クライアント シークレット
GOOGLE_CLIENT_SECRET=
# 注意：対応する Client ID は現状 api/gcal-start.js にハードコードされています。
#       自分のプロジェクトで使う場合は api/gcal-start.js の CLIENT_ID も差し替えてください。

# ── Webプッシュ（VAPID）──
# 生成： npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 連絡先（mailto: 形式）
VAPID_SUBJECT=mailto:you@example.com

# ── 毎朝のプッシュ送信（Vercel Cron）の認証 ──
# 任意の長い乱数文字列。未設定だと cron 認証がスキップされるため、本番では必ず設定。
CRON_SECRET=

# ── firebase-admin（サーバーからFirestoreを読む：プッシュ集計用）──
# Firebase Console > プロジェクト設定 > サービスアカウント > 新しい秘密鍵を生成（JSON）から
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 秘密鍵。改行は \n のままでも実改行でも可（api/_admin.js が両対応）
FIREBASE_PRIVATE_KEY=
