rules_version = '2';

// VIELE secretary — 本人だけ読み書き可 ＋ メール許可リスト
service cloud.firestore {
  match /databases/{database}/documents {

    // 自分のUIDのドキュメントだけアクセス可
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && isAllowed();

      // 配下のサブコレクションも同じ本人のみ
      match /{document=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid
                           && isAllowed();
      }
    }

    // ── 事前登録（waitlist）──────────────────────────────────────
    // 許可リスト外の人でも、ログインさえすれば「自分の事前登録」だけは作れる。
    //   ・LPから入って許可リスト外だった人を“行き止まり”にせず、見込み客として名簿に貯める。
    //   ・他人の登録の閲覧・一覧・削除はクライアントから不可（名簿はオーナーがコンソールで見る）。
    //   ・保存できるのは email / name / ts の3項目のみ（巨大データ書き込み等の悪用を防ぐ）。
    match /waitlist/{uid} {
      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && request.resource.data.keys().hasOnly(['email', 'name', 'ts']);
      allow read, delete: if false;
    }

    // ── ALLOWLIST（メール許可リスト）─────────────────────────────
    // 「使わせたい知人のGoogleメール」をここに列挙する。
    //   ・各自は自分のアカウント・自分のデータで利用する（制限ではなく入場許可）。
    //   ・リストに無いアカウントは登録・利用できない＝野良ユーザーやコスト悪用を防ぐ。
    //   ・追加/削除したら firebase deploy --only firestore:rules（または
    //     Firebaseコンソール > Firestore > ルール に貼り付け）で反映。
    //   ・ALLOWLIST を空配列 [] にすると「ログイン本人のみ・全員許可」に戻る。
    // ※ 下のメールは仮置き。自分のログイン用Gmailと知人のメールに置き換えること。
    function isAllowed() {
      let ALLOWLIST = [
        "kururin100542@gmail.com"
        // , "friend1@gmail.com"
        // , "friend2@gmail.com"
      ];
      return ALLOWLIST.size() == 0
             || (request.auth.token.email_verified == true
                 && request.auth.token.email in ALLOWLIST);
    }
  }
}
