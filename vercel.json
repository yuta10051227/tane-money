{
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    },
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
    }
  ],
  "crons": [
    { "path": "/api/cron-reengage", "schedule": "0 9 * * *" }
  ],
  "rewrites": [
    { "source": "/((?!api/|lp/|lp$).*)", "destination": "/index.html" }
  ]
}
