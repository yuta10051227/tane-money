rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Tane Money: 家族データ ──
    // 前提: アプリは匿名認証(signInAnonymously)でサインインする。
    // ファミリーコード(TANE-XXXX-XXXX, 暗号乱数8文字)を知っていることが参加証明＝ドキュメントID。
    // 重要: read を get に限定し list(コレクション列挙)は禁止。
    //   → コードを知らない者が families コレクションを一覧ダンプできないようにする。
    // delete は不可(アプリに家族ドキュメント削除フローは無い。任意家族の消去攻撃を防ぐ)。
    // ※App Check は未実装。導入したら総当たり耐性が上がる(認可の代替ではない)。
    match /families/{code} {
      allow get:  if request.auth != null;   // コード(ID)を知っている時だけ1件取得
      allow list: if false;                  // コレクション列挙・全家族ダンプを禁止
      allow write: if request.auth != null
                   && request.resource.data.keys().hasOnly(['data','updatedAt'])
                   && request.resource.data.data is string
                   && request.resource.data.data.size() < 900000; // 1MB制限の手前で停止
      allow delete: if false;

      // ログ（追記専用コレクション。同一家族配下なのでコードを知る前提・queryのためread許可）
      match /logs/{logId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.date is string
                      && request.resource.data.pts is number;
        // ログは改ざん・削除不可（取り消しは逆仕訳エントリの追記で行う設計）
        allow update, delete: if false;
      }

      // 課金エンタイトルメント(meta/billing 等)。サーバー(Stripe Webhook + Admin SDK)が
      // 書き込み、クライアントは read のみ。クライアントからの改ざんを防ぐため write は禁止
      //（Admin SDK はルールをバイパスするのでサーバー書き込みは可能）。
      match /meta/{doc} {
        allow get: if request.auth != null;
        allow list, write: if false;
      }
    }

    // それ以外（viele-secretary等の別アプリのコレクションを含む）は
    // このルールファイルでは一切許可しない
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
